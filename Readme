cat > internal_resolvers.txt <<EOF
10.10.1.10
10.10.1.11
EOF

# dnsx — resolve + PTR sweep a whole /16 to paint a hostname map
dnsx -l subdomains.txt -r internal_resolvers.txt -a -aaaa -cname -ns -mx -txt -resp -o dnsx_recs.txt
echo 10.10.0.0/16 | dnsx -ptr -resp -r internal_resolvers.txt -silent -o ptr_10.10.txt

# puredns — subdomain brute against internal resolver (CRITICAL: --skip-validation + trusted=internal)
puredns bruteforce /opt/wordlists/SecLists/Discovery/DNS/subdomains-top1million-110000.txt \
        corp.local \
        --resolvers internal_resolvers.txt \
        --resolvers-trusted internal_resolvers.txt \
        --skip-validation --rate-limit 500 \
        --write corp_local_subs.txt --write-wildcards corp_local_wildcards.txt

# dig — AXFR attempts + SRV for DCs/Exchange/KMS/WPAD
for zone in corp.local corp.internal dev.corp.local; do
  for ns in $(dig @10.10.1.10 +short NS $zone); do
    dig @$ns $zone AXFR +nocomments +nostats
  done
done | tee axfr.txt

for srv in _kerberos._tcp _ldap._tcp _ldap._tcp.dc._msdcs _gc._tcp \
           _autodiscover._tcp _http._tcp _vlmcs._tcp _wpad._tcp; do
  dig @10.10.1.10 +short SRV ${srv}.corp.local
done

# dnsrecon — reverse CIDR + cache snoop
dnsrecon -r 10.10.0.0/16 -n 10.10.1.10 -t rvl -j rvl.json
dnsrecon -t snoop -n 10.10.1.10 -D cache_snoop_wordlist.txt
